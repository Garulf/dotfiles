# Tmux auto-attach logic
is_tmux() {
  # $- contains 'i' when shell is interactive (works in bash and zsh)
  command -v tmux &>/dev/null &&
    [[ $- == *i* ]] &&
    [[ -z "$TMUX" ]]
}

tmux_shell() {
  is_tmux || return
  local session
  session=$(tmux ls 2>/dev/null | grep -v attached | head -1 | cut -d: -f1)
  if [[ -n "$session" ]]; then
    exec tmux attach -t "$session"
  else
    exec tmux
  fi
}

# Helper functions
function mkd() {
  mkdir -p "$@" && cd "$_"
}

function o() {
  if [ $# -eq 0 ]; then
    open .
  else
    open "$@"
  fi
}

function tre() {
  tree -aC -I '.git|node_modules|bower_components' --dirsfirst "$@" | less -FRNX
}

# Git helpers
function ga() {
  if [ "$#" -eq 0 ]; then
    git add -v .
  else
    git add -v "$@"
  fi
}

function gac() { git add -v . && git commit -m "$1" }
function gacp() { gac "$1" && git push }

# Bitwarden wrapper — auto-unlocks only when command fails due to auth
function bw() {
  command bw "$@" && return
  local bw_status
  bw_status=$(command bw status 2>/dev/null | grep -o '"status":"[^"]*"' | cut -d'"' -f4)
  if [[ "$bw_status" == "unauthenticated" ]]; then
    export BW_SESSION=$(command bw login --raw)
  elif [[ "$bw_status" == "locked" ]]; then
    export BW_SESSION=$(command bw unlock --raw)
  else
    return 1
  fi
  [[ -z "$BW_SESSION" ]] && return 1
  command bw "$@"
}

# Use a Bitwarden login entry (identified by shell://<hostname> URL) as the sudo password.
# Store entries in Bitwarden with URL: shell://<hostname> and username matching your shell user.
function bsudo() {
  local host_url="shell://$(hostname -s)"
  local items password

  items=$(bw list items --url "$host_url" 2>/dev/null) || return 1

  password=$(jq -r --arg user "$USER" '
    (map(select(.login.username == $user)) | first // first) | .login.password
  ' <<< "$items" 2>/dev/null)

  if [[ -z "$password" || "$password" == "null" ]]; then
    echo "bsudo: no Bitwarden entry found for $host_url (username: $USER)" >&2
    return 1
  fi

  echo "$password" | sudo -S -p '' "$@"
}

# cd to (or create) ~/projects/<name>, or clone a repo with -c <owner/repo|url>
function proj() {
  if [[ "$1" == "-c" ]]; then
    local spec="$2"
    if [[ -z "$spec" ]]; then
      echo "usage: proj -c <owner/repo|url>" >&2
      return 1
    fi

    # gh resolves the repo's canonical case (e.g. garulf/steam-search -> Garulf/Steam-Search)
    local full_name
    full_name=$(gh repo view "$spec" --json nameWithOwner -q .nameWithOwner 2>/dev/null)
    if [[ -z "$full_name" ]]; then
      echo "proj: could not resolve repo '$spec'" >&2
      return 1
    fi

    local dir="$HOME/projects/${full_name#*/}"
    if [[ -d "$dir" ]]; then
      cd "$dir"
      return
    fi

    gh repo clone "$full_name" "$dir" || return
    cd "$dir"
    return
  fi

  local name="$1"
  if [[ -z "$name" ]]; then
    find "$HOME/projects" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null
    return
  fi

  local dir="$HOME/projects/$name"
  mkdir -p "$dir"
  cd "$dir"
}

if [[ -n "$ZSH_VERSION" && -o interactive ]] && (( ${+_comps} )); then
  _proj() { _path_files -W "$HOME/projects" -/ }
  # znap shadows compdef with a stub that silently drops calls made after
  # compinit, so register directly in the completion registry instead
  _comps[proj]=_proj
fi

# Fetch a .gitignore for the given space-separated languages/tools (e.g. `gitignore python node vim`)
# and write it to ./.gitignore, or append with `gitignore -a <names...>`.
function gitignore() {
  local append=0
  if [[ "$1" == "-a" ]]; then
    append=1
    shift
  fi

  if [[ $# -eq 0 ]]; then
    echo "usage: gitignore [-a] <name> [name...]" >&2
    return 1
  fi

  local query
  query=$(IFS=,; echo "$*")

  local content
  content=$(curl -sf "https://www.gitignore.io/api/${query}") || {
    echo "gitignore: failed to fetch template for: $*" >&2
    return 1
  }

  if (( append )); then
    echo "$content" >>.gitignore
  else
    echo "$content" >.gitignore
  fi
}

# Editor helpers
cdv() {
  if [ -d "$1" ]; then
    cd "$1"
  fi
  nvim "$1"
}