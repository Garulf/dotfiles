[user]
	email = 535299+Garulf@users.noreply.github.com
	name = Garulf
# Note: NixOS-specific gh credential path
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[alias]
	ac = !git add -A && git commit -m
	ignore = "!f() { url=\"https://raw.githubusercontent.com/github/gitignore/master/$1.gitignore\"; curl --output /dev/null --silent --head --fail \"$url\"; if [ $? -eq 0 ]; then curl \"$url\" >> .gitignore && echo \"Appended .gitignore with $url\"; else echo \"$url does not exist.\"; fi; }; f"
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[init]
	defaultBranch = main
